# --- Local MongoDB (no Docker) ---
# MONGODB_URI=mongodb://localhost:27017

# --- MongoDB Atlas ---
# MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/poll-live-feed?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB_NAME=poll-live-feed

# If your MongoDB requires a user/password (see Compass connection string):
# MONGODB_URI=mongodb://USERNAME:PASSWORD@localhost:27017/?authSource=admin

# --- Docker MongoDB from this repo (host port 27018) ---
# MONGODB_URI=mongodb://app:app@localhost:27018/?authSource=admin
# MONGODB_DB_NAME=registrations

GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_LOCATION=us
GOOGLE_DOCUMENTAI_PROCESSOR_ID=your-processor-id
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Production (VPS + Vercel)
# CORS_ORIGINS=https://your-app.vercel.app,https://poll.edumatrix.com
# SUPER_ADMIN_EMAIL=admin@ogun.monitor
# SUPER_ADMIN_PASSWORD=use-a-strong-password-here
#
# Docker (recommended on VPS): see backend/docker-compose.yml and deploy/env.docker.example
