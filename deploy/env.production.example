# Copy to ../.env on the VPS and fill in real values.
# Path on server example: /home/USER/edumatrix/poll/.env

MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=poll-live-feed

# If MongoDB has auth:
# MONGODB_URI=mongodb://polluser:STRONG_PASSWORD@127.0.0.1:27017/?authSource=admin

GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_LOCATION=us
GOOGLE_DOCUMENTAI_PROCESSOR_ID=your-processor-id
GOOGLE_APPLICATION_CREDENTIALS=/home/USER/edumatrix/poll/service-account.json

SUPER_ADMIN_EMAIL=admin@ogun.monitor
SUPER_ADMIN_PASSWORD=change-this-before-going-live

# Your Vercel frontend URL(s), comma-separated (no trailing slash)
CORS_ORIGINS=https://your-app.vercel.app
