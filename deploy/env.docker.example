# Copy to ../.env on the VPS poll folder: cp deploy/env.docker.example .env

# MongoDB Atlas (recommended for production)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/poll-live-feed?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB_NAME=poll-live-feed

SUPER_ADMIN_EMAIL=admin@ogun.monitor
SUPER_ADMIN_PASSWORD=change-this-before-going-live

# Vercel frontend URL(s), comma-separated
CORS_ORIGINS=https://your-app.vercel.app

GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_LOCATION=us
GOOGLE_DOCUMENTAI_PROCESSOR_ID=
GOOGLE_APPLICATION_CREDENTIALS=/app/service-account.json
